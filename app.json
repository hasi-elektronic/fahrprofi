    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hasielektronic.fahrprofi"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1117"
      },
      "package": "com.hasielektronic.fahrprofi"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "fahrprofi"
